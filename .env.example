# Copy this file to .env before running locally:
#   cp .env.example .env
#
# This file is safe to commit — do NOT put real secrets here.

# PostgreSQL connection string.
# For docker compose (db service on host port 55432):
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/module13_db

# Secret key used to sign JWT tokens. Must be at least 32 characters.
# Generate a strong one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret

# JWT signing algorithm — do not change.
JWT_ALGORITHM=HS256

# How long issued tokens remain valid (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=60
